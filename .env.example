# Copy to .env.local and fill in. .env.local is gitignored.
# None of these are required for the initial Vercel deploy — placeholders work,
# the corresponding feature just won't ship until the key is set.

# --- Newsletter capture (footer signup form) ------------------------------
# Sign up at https://beehiiv.com, create a publication, grab the API key from
# Settings → Integrations → API. Without these the /api/newsletter route
# returns 503 and the form shows an honest error.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# --- Inner Circle application intake (/api/apply) -------------------------
# Sign up at https://resend.com (free tier, ~30 sec). Grab the API key from
# the dashboard. Without it the /apply route returns 503.
RESEND_API_KEY=

# Optional overrides. Defaults are:
#   from: "Lockr Apply <onboarding@resend.dev>"  (Resend's no-verify sender)
#   to:   "hello@joinlockr.com"
# Verify joinlockr.com in Resend if you want a branded From address —
# big deliverability win, ~10 min of DNS work.
# APPLY_FROM_EMAIL="Lockr <apply@joinlockr.com>"
# APPLY_TO_EMAIL=hello@joinlockr.com

# --- Payments + community access ------------------------------------------
# All payments, subscription billing, Discord role assignment, and member
# access flows are handled by Whop. No env vars needed on our side — the
# integration is a redirect to whop.com/checkout/<plan_id> and Whop owns
# the rest. Plan IDs are baked into lib/copy.ts (whopCheckoutUrl helper).

# --- Error reporting (optional, pick before launch) -----------------------
# SENTRY_DSN=
